+/// Base class for objects that are managed on the stack rather than the heap.
+///
+/// Stack-managed objects (like Environment) are not subject to garbage collection
+/// because their lifetime is managed by the call stack. They are created and
+/// destroyed in a predictable, stack-based manner.
+///
+/// Examples: Environment, CallFrame
+abstract class StackObject {
+  /// Stack objects don't need GC methods since they're not heap-managed
+}
+
+/// Base class for objects that live on the heap and are subject to garbage collection.
+///
+/// Heap-managed objects extend GCObject and participate in the garbage collection
+/// process. They can be collected when they become unreachable.
+///
+/// Examples: Value, Box, Upvalue, Coroutine
+abstract class HeapObject extends GCObject {
+  /// Heap objects inherit all GC functionality from GCObject
+}
+
+/// Base class for objects that should never be garbage collected.
+///
+/// Root objects are always considered reachable and are never collected.
+/// They typically represent core runtime objects or singletons.
+///
+/// Examples: Main thread, Global environment (though Environment is now StackObject)
+abstract class RootObject {
+  /// Root objects are never collected, so they don't need GC methods
+}
