set shell := ["zsh", "-cu"]

# Build and run the CLI with arbitrary arguments.
# Usage: just lualike --ir --emit-llvm -e "1+2"
lualike *args:
    dart build cli --target=bin/main.dart --verbosity=error
    ./build/cli/linux_x64/bundle/bin/main {{ args }}

# Build a standalone CLI binary for testing.
compile:
    dart build cli --target=bin/main.dart

# Run luascripts/compare/*.lua through the LLVM pipeline and validate with
# llc.  Only tests scripts in the compilable subset.  Uses existing CLI
# binary — run `just compile` first if needed.
#   just check-all          — all compilable scripts
#   just check-all 01_arith — only 01_arith*
check-all *name="":
    -zsh tool/check_llvm_all.sh {{name}}

# Run a snippet with the AST interpreter and debug output.
run +ARG:
    dart run bin/main.dart --debug -e "{{ARG}}"

# Run a snippet with the AST interpreter.
check +ARG:
    dart run bin/main.dart -e "{{ARG}}"

# Compare IR output with reference Lua.
compare *ARG='':
    dart run tool/compare.dart {{ARG}}

# Compile a Lua script to native code via the Dart AOT backend.
# Usage: just aot script.lua [output]
#   1. Generates Dart source from Lua
#   2. Compiles with dart compile exe
#   3. Runs the result
aot *args:
    zsh tool/aot_compile.sh {{args}}

# Compile a Lua script to native via the LLVM pipeline.
# Usage: just native script.lua [output]
native *args:
    zsh tool/compile_to_native.sh {{args}}

# Build and drop into a REPL.
repl: compile
    ./build/cli/linux_x64/bundle/bin/main

# Run integration tests via compiled test runner.
tool-test *ARG='':
    # Ensure compiled test runner exists
    if [ ! -x test_runner ]; then \
      dart compile exe tool/test.dart -o test_runner; \
    fi

    # Run tests using compiled runner and binary
    ./test_runner {{ARG}}

# Compile the standalone test runner binary.
test-tool-compile:
    dart compile exe tool/test.dart -o test_runner
